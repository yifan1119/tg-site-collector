# tg-site-collector · 环境变量样例 · 复制成 .env 后填值

# ─── Temporal ───
TEMPORAL_HOST=localhost:7233
TEMPORAL_TASK_QUEUE=site-collector

# ─── Tavily 搜索(必需)───
# 注册 https://tavily.com 拿 API key
TAVILY_API_KEY=tvly-CHANGEME

# ─── Telegram 推送(可选)───
# @BotFather 申请 bot 拿 token · https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ─── 数据目录(多租户隔离根)───
DATA_ROOT=./data
B_AUDIT_DIR=./data/audit

# ─── 鉴权模式 ───
# stub  · 默认 · 全部 allow(开发用)
# http  · 真调你自己的 IAM endpoint(改 auth_activity.py 适配你的 contract)
# deny  · 强制 deny · 测试 fail-closed 用
AUTH_MODE=stub
AUTH_BASE=http://localhost:8000

# ─── Playwright ───
PLAYWRIGHT_HEADLESS=true
NAV_EXPAND_MAX_CANDIDATES=50

# ─── 日志 ───
LOG_LEVEL=INFO
